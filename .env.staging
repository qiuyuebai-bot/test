# ===========================================
# 预发布环境配置（vite build --mode staging）
# 用于 staging 环境验证，Sentry 开启但采样率较低
# ===========================================

# Sentry 错误监控（staging 环境开启，低采样率）
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=staging
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# 调试模式（staging 关闭）
VITE_DEBUG=false
