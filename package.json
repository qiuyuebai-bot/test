{
  "name": "domain-knowledge-multiagent-system",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "node scripts/start.mjs",
    "start:setup": "node scripts/start.mjs --setup",
    "start:backend": "node scripts/start.mjs --backend",
    "start:frontend": "node scripts/start.mjs --frontend",
    "build": "tsc && vite build",
    "build:staging": "tsc && vite build --mode staging",
    "build:dev": "tsc && vite build --mode development",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "openapi:export": "cd backend && venv\\Scripts\\python.exe scripts/export_openapi.py",
    "openapi:check": "cd backend && venv\\Scripts\\python.exe scripts/export_openapi.py --check",
    "openapi:types": "openapi-typescript docs/api/openapi.json -o src/types/api/generated.ts",
    "openapi:gen": "npm run openapi:export && npm run openapi:types"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@sentry/react": "^10.64.0",
    "@tanstack/react-query": "^5.101.2",
    "clsx": "^2.1.0",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0",
    "zod": "^4.4.3",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.6.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^24.1.3",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.2.2",
    "vite": "^5.1.4",
    "vitest": "^1.6.1"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
