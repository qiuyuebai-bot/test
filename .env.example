# ===========================================
# 环境变量配置模板
# 复制此文件为 .env 并根据实际环境修改
# ===========================================

# ---- 端口配置 ----
FRONTEND_PORT=80
BACKEND_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
CHROMA_PORT=8001

# ---- 数据库配置 ----
# 开发/演示模式使用 SQLite（默认，无需额外配置）
# DATABASE_URL=sqlite:////app/data/app.db
# 生产模式使用 PostgreSQL（需要 --profile full）
DATABASE_URL=postgresql://postgres:password@postgres:5432/knowledge_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=knowledge_system

# ---- 安全配置 ----
# ⚠️ 生产环境务必修改为随机强密钥
SECRET_KEY=change-me-in-production-please-use-a-random-string
DEBUG_MODE=false

# ---- 大模型配置 ----
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4-turbo-preview
