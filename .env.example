# ===========================================
# 前端环境变量配置模板
# 复制需要的项到 .env.local（本地覆盖，不提交 Git）
#
# Vite 多环境文件加载顺序（后者覆盖前者）：
#   .env                所有模式共享
#   .env.development     vite dev / vite build --mode development
#   .env.staging         vite build --mode staging
#   .env.production      vite build（默认 mode=production）
#   .env.*.local         本地覆盖，不提交 Git（最高优先级）
# ===========================================

# ---- 应用信息 ----
VITE_APP_VERSION=1.0.0

# ---- API 配置 ----
# 留空则使用相对路径 /api/v1（适用于前后端同域部署，由 Nginx 反代）
# 分离部署时设为后端完整地址，如 https://api.example.com/api/v1
VITE_API_BASE_URL=

# ---- Sentry 错误监控（可选，DSN 留空则自动降级为 no-op） ----
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# ---- 调试模式 ----
VITE_DEBUG=false
