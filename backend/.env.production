# ===========================================
# 生产环境配置（APP_ENV=production）
# 生产部署使用，敏感字段通过 K8s Secret 注入，此处仅作模板
# ===========================================

APP_ENV=production

# 关闭调试模式（必须）
DEBUG_MODE=false

# 数据库：PostgreSQL 连接（实际密码通过 K8s Secret 注入）
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/knowledge_system

# CORS：生产域名（必须改为具体域名）
CORS_ORIGINS=https://your-domain.com

# JWT 有效期（生产建议较短）
JWT_EXPIRE_MINUTES=60

# 固定 SECRET_KEY（生产必须设置，通过 K8s Secret 注入）
# SECRET_KEY=（通过环境变量注入，不写入文件）

# 默认管理员密码（生产必须修改）
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_IMMEDIATELY

# 速率限制（生产标准）
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_API=100/minute
RATE_LIMIT_UPLOAD=20/minute

# 可信代理（生产负载均衡器 IP）
TRUSTED_PROXIES=10.0.0.1,10.0.0.2

# LLM 熔断器（生产开启）
LLM_CIRCUIT_BREAKER_ENABLED=true
LLM_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
LLM_CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# 数据脱敏（生产全部开启）
ANONYMIZE_NAME=true
ANONYMIZE_PHONE=true
ANONYMIZE_ID_CARD=true
ANONYMIZE_ADDRESS=true
