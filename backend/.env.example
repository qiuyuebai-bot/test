# ===========================================
# 系统配置文件模板
# 使用方法: 复制为 .env 并填写实际值
#
# 多环境支持：
#   APP_ENV=development  加载 .env + .env.development
#   APP_ENV=staging       加载 .env + .env.staging
#   APP_ENV=production    加载 .env + .env.production
# 加载顺序：.env（基础）→ .env.{APP_ENV}（覆盖）→ 环境变量（最高优先级）
# ===========================================

# 运行环境（development / staging / production）
APP_ENV=development

# 数据库配置
DATABASE_URL=postgresql://username:password@localhost:5432/knowledge_system
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis配置 (Celery异步任务队列)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 向量数据库配置
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION_NAME=knowledge_slices
EMBEDDING_MODEL_PATH=./models/embedding_model

# 大模型配置
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# 文件存储配置
UPLOAD_DIR=./data/uploads
KNOWLEDGE_DOC_DIR=./data/knowledge_docs
RESOURCE_OUTPUT_DIR=./data/resources
LOG_DIR=./logs

# 安全配置
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
# 默认管理员密码：首次启动创建 admin 账户时使用，生产环境务必覆盖
DEFAULT_ADMIN_PASSWORD=admin123

# 系统配置
APP_NAME=领域知识个性化生成与多智能体协同决策系统
APP_VERSION=1.0.0
DEBUG_MODE=true
API_PREFIX=/api/v1

# 脱敏配置
ANONYMIZE_NAME=true
ANONYMIZE_PHONE=true
ANONYMIZE_ID_CARD=true
ANONYMIZE_ADDRESS=true

# 指标计算配置
HALLUCINATION_THRESHOLD=5.0
MATCH_ACCURACY_THRESHOLD=90.0
KNOWLEDGE_COVERAGE_THRESHOLD=95.0