# ===========================================
# 预发布环境配置（APP_ENV=staging）
# 用于 staging 环境验证，接近生产配置
# ===========================================

APP_ENV=staging

# 关闭调试模式
DEBUG_MODE=false

# 数据库：PostgreSQL
DATABASE_URL=postgresql://postgres:password@postgres:5432/knowledge_system

# CORS：staging 域名
CORS_ORIGINS=https://staging.example.com

# JWT 有效期
JWT_EXPIRE_MINUTES=60

# 速率限制（标准）
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_API=100/minute

# 可信代理（staging 负载均衡器 IP）
# TRUSTED_PROXIES=10.0.0.1,10.0.0.2

# LLM 熔断器（staging 开启）
LLM_CIRCUIT_BREAKER_ENABLED=true
